# Terraform working directory
.terraform/

# Terraform state files
*.tfstate
*.tfstate.*

# Terraform lock file (optional)
# Keep this if you're working in a team to lock provider versions.
# Remove the next line if you want to commit it.
.terraform.lock.hcl

# Variable files containing secrets
*.tfvars
*.tfvars.json

# Crash logs
crash.log
crash.*.log

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Terraform plan files
*.tfplan
*.plan

# CLI configuration files
.terraformrc
terraform.rc